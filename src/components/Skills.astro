---
import { skillGroups } from '../data/skills';
---

<section id="skills">
  <div class="container">
    <div class="fade-up">
      <p class="section-tag">Skills</p>
      <h2 class="section-title">The full toolkit</h2>
      <p class="section-lead">Tools I reach for to build things that work in production — not just in notebooks.</p>
    </div>

    <div class="grid fade-up">
      {skillGroups.map(g => (
        <div class="group">
          <p class="group-label">{g.label}</p>
          <div class="chips">
            {g.skills.map(s => <span class="chip">{s}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .grid { display: flex; flex-direction: column; gap: 28px; margin-top: 16px; }
  .group-label {
    font-size: 11px; font-weight: 600; letter-spacing: 1.5px;
    text-transform: uppercase; color: var(--accent2); margin-bottom: 10px;
  }
  .chips { display: flex; flex-wrap: wrap; gap: 8px; }
  .chip {
    font-size: 13px; font-weight: 500;
    background: var(--bg3); border: 1px solid var(--border);
    color: var(--text-muted); padding: 5px 14px; border-radius: 6px;
    transition: border-color .2s, color .2s;
  }
  .chip:hover { border-color: var(--accent2); color: var(--accent3); }
</style>
