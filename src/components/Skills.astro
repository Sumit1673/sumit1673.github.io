---
import { skillGroups } from '../data/skills';
---

<section id="skills">
  <div class="container">
    <div class="reveal">
      <p class="section-eyebrow">Skills</p>
      <h2 class="section-title">The full toolkit</h2>
      <p class="section-lead">Tools I reach for to build things that work in production — not just in notebooks.</p>
    </div>

    <div class="groups">
      {skillGroups.map((g, gi) => (
        <div class="group reveal" style={`--gi:${gi}`}>
          <div class="group-header">
            <span class="group-label">{g.label}</span>
            <span class="group-count">{g.skills.length}</span>
          </div>
          <div class="chips">
            {g.skills.map((s, si) => (
              <span class="chip" style={`--si:${si}`}>{s}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  section { background: var(--bg); }
  section::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 40% 40% at 10% 50%, rgba(99,102,241,.07) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 90% 50%, rgba(244,114,182,.05) 0%, transparent 70%);
    pointer-events: none;
  }

  .groups {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .group {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: 24px 22px;
    transition: border-color .25s, transform .25s, box-shadow .25s;
    transition-delay: calc(var(--gi) * 60ms);
  }
  .group:hover {
    border-color: var(--border2); transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(0,0,0,.2);
  }

  .group-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 14px;
  }
  .group-label {
    font-size: 11px; font-weight: 700; letter-spacing: 1.5px;
    text-transform: uppercase; color: var(--accent2);
  }
  .group-count {
    font-size: 11px; font-weight: 600;
    background: rgba(99,102,241,.1); color: var(--accent3);
    border: 1px solid rgba(99,102,241,.2);
    padding: 2px 8px; border-radius: 99px;
  }

  .chips { display: flex; flex-wrap: wrap; gap: 7px; }
  .chip {
    font-size: 12.5px; font-weight: 500;
    background: var(--bg3); border: 1px solid var(--border);
    color: var(--text-muted); padding: 5px 13px; border-radius: 8px;
    transition: border-color .2s, color .2s, background .2s, transform .15s;
    cursor: default;
  }
  .chip:hover {
    border-color: var(--accent2); color: var(--accent3);
    background: rgba(99,102,241,.06); transform: translateY(-1px);
  }

  @media (max-width: 720px) {
    .groups { grid-template-columns: 1fr; }
  }
</style>
