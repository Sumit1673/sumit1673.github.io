---

<section id="contact">
  <div class="container">
    <div class="inner">
      <div class="left reveal reveal-left">
        <p class="section-eyebrow">Contact</p>
        <h2 class="section-title">Let's talk</h2>
        <p class="lead">
          I'm actively looking for Staff / Sr. Staff ML Engineer roles in Canada or the US.
          If you're hiring, have an interesting problem, or just want to talk shop about
          RAG systems and LLMs — reach out. I reply to everything.
        </p>
        <div class="links">
          {links.map((l, i) => (
            <a
              href={l.href}
              target={l.target}
              rel={l.target ? 'noopener noreferrer' : undefined}
              class="link"
              style={`--color:${l.color}; --i:${i}`}
            >
              <span class="link-icon" set:html={l.icon} />
              <span class="link-text">
                <span class="link-label">{l.label}</span>
                <span class="link-sub">{l.sublabel}</span>
              </span>
              <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M7 7h10v10"/></svg>
            </a>
          ))}
        </div>
      </div>

      <div class="right reveal reveal-right">
        <div class="cta-box">
          <div class="cta-glow"></div>
          <div class="cta-inner">
            <div class="cta-icon">👋</div>
            <h3>Open to work</h3>
            <p>Looking for Staff ML / AI Engineer roles in Canada or the US. Remote-first preferred.</p>
            <div class="cta-tags">
              <span>Staff ML Engineer</span>
              <span>AI Engineer</span>
              <span>MLOps Lead</span>
              <span>RAG Architect</span>
            </div>
            <a href="mailto:sumitvaise29@gmail.com" class="cta-btn">
              Send me an email →
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  section { background: var(--bg); }
  section::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 60% 60% at 50% 100%, rgba(99,102,241,.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .inner {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 64px; align-items: start;
  }

  .lead { color: var(--text-muted); font-size: 15px; line-height: 1.8; margin-bottom: 36px; }

  .links { display: flex; flex-direction: column; gap: 10px; }
  .link {
    display: flex; align-items: center; gap: 14px;
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 14px 18px;
    color: var(--text); transition: border-color .25s, transform .2s, box-shadow .25s;
    transition-delay: calc(var(--i) * 60ms);
  }
  .link:hover {
    border-color: var(--color, var(--accent));
    transform: translateX(4px);
    box-shadow: -4px 0 20px rgba(99,102,241,.1);
    color: var(--text);
  }
  .link-icon :global(svg) {
    width: 20px; height: 20px; flex-shrink: 0;
    color: var(--color, var(--accent2));
  }
  .link-text { flex: 1; display: flex; flex-direction: column; }
  .link-label { font-size: 13px; font-weight: 600; color: var(--text); }
  .link-sub { font-size: 11px; color: var(--text-muted); margin-top: 1px; }
  .arrow { color: var(--text-dim); flex-shrink: 0; transition: transform .2s, color .2s; }
  .link:hover .arrow { transform: translate(2px, -2px); color: var(--text-muted); }

  /* CTA box */
  .right { position: sticky; top: 80px; }
  .cta-box { position: relative; border-radius: var(--radius-xl); overflow: hidden; }
  .cta-glow {
    position: absolute; inset: -1px; border-radius: var(--radius-xl);
    background: linear-gradient(135deg, var(--accent) 0%, var(--pink) 50%, var(--accent2) 100%);
    opacity: .6;
    animation: shimmer 4s linear infinite;
    background-size: 200% auto;
  }
  @keyframes shimmer {
    0%   { background-position: 0% center; }
    100% { background-position: 200% center; }
  }
  .cta-inner {
    position: relative; z-index: 1;
    background: var(--bg3);
    border-radius: calc(var(--radius-xl) - 1px);
    padding: 36px 32px;
    display: flex; flex-direction: column; gap: 16px;
  }
  .cta-icon { font-size: 36px; }
  .cta-inner h3 { font-size: 22px; font-weight: 800; letter-spacing: -.5px; }
  .cta-inner p { font-size: 14px; color: var(--text-muted); line-height: 1.7; }

  .cta-tags { display: flex; flex-wrap: wrap; gap: 7px; }
  .cta-tags span {
    font-size: 11px; font-weight: 600;
    background: rgba(99,102,241,.1); color: var(--accent3);
    border: 1px solid rgba(99,102,241,.2); padding: 4px 11px; border-radius: 99px;
  }
  .cta-btn {
    display: inline-flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, var(--accent), #7c3aed);
    color: #fff !important; font-size: 14px; font-weight: 700;
    padding: 14px 24px; border-radius: 10px; margin-top: 4px;
    box-shadow: 0 8px 24px rgba(99,102,241,.4);
    transition: opacity .2s, transform .2s, box-shadow .2s;
  }
  .cta-btn:hover {
    opacity: .9; transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(99,102,241,.55);
  }

  @media (max-width: 720px) {
    .inner { grid-template-columns: 1fr; gap: 40px; }
    .right { position: static; }
  }
</style>
