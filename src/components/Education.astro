---
const tags = ['Machine Learning', 'Computer Vision', 'Cloud Computing', 'Deep Learning', 'Neural Networks'];
---

<section id="education">
  <div class="container">
    <div class="fade-up">
      <p class="section-tag">Education</p>
      <h2 class="section-title">Academic background</h2>
    </div>
    <div class="card fade-up">
      <span class="icon">🎓</span>
      <div>
        <div class="degree">Master of Engineering (MEng)</div>
        <div class="uni">Concordia University</div>
        <div class="meta">
          <span class="date">Jan 2019 – Dec 2020</span>
          <span class="location">📍 Montreal, QC, Canada</span>
        </div>
        <div class="tags">
          {tags.map(t => <span class="tag">{t}</span>)}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .card {
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: 28px 30px;
    display: flex; gap: 20px; align-items: flex-start;
    margin-top: 32px;
    transition: border-color .2s;
  }
  .card:hover { border-color: var(--accent); }
  .icon { font-size: 28px; flex-shrink: 0; }
  .degree { font-size: 16px; font-weight: 700; color: var(--text); margin-bottom: 3px; }
  .uni { font-size: 14px; font-weight: 500; color: var(--accent2); margin-bottom: 8px; }
  .meta { display: flex; gap: 16px; align-items: center; flex-wrap: wrap; margin-bottom: 14px; }
  .date {
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    color: var(--text-dim); background: var(--bg2);
    border: 1px solid var(--border); padding: 2px 9px; border-radius: 4px;
  }
  .location { font-size: 12px; color: var(--text-muted); }
  .tags { display: flex; flex-wrap: wrap; gap: 7px; }
  .tag {
    font-size: 12px; font-weight: 500;
    background: rgba(99,102,241,.08); color: var(--accent3);
    border: 1px solid rgba(99,102,241,.18); padding: 3px 11px; border-radius: 5px;
  }
</style>
