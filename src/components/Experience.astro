---
import { experience } from '../data/experience';
---

<section id="experience">
  <div class="container">
    <div class="fade-up">
      <p class="section-tag">Experience</p>
      <h2 class="section-title">Where I've worked</h2>
      <p class="section-lead">Five companies. Each one taught me something different about shipping ML at scale.</p>
    </div>

    <div class="timeline fade-up">
      {experience.map(role => (
        <div class="item">
          <div class="dot"></div>
          <div class="header">
            <div>
              <div class="role-title">{role.title}</div>
              <div class="company">{role.company} · {role.location}</div>
            </div>
            <span class="date">{role.period}</span>
          </div>
          <ul class="bullets">
            {role.bullets.map(b => <li set:html={b} />)}
          </ul>
          <div class="tags">
            {role.tags.map(t => <span class="tag">{t}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .timeline { position: relative; margin-top: 16px; }
  .timeline::before {
    content: ''; position: absolute; left: 0; top: 8px; bottom: 0;
    width: 2px; background: var(--border);
  }
  .item { position: relative; padding-left: 28px; padding-bottom: 40px; }
  .item:last-child { padding-bottom: 0; }

  .dot {
    position: absolute; left: -5px; top: 8px;
    width: 12px; height: 12px;
    background: var(--accent); border-radius: 50%;
    border: 2px solid var(--bg);
    box-shadow: 0 0 0 2px var(--accent);
  }

  .header {
    display: flex; justify-content: space-between;
    align-items: flex-start; gap: 16px; flex-wrap: wrap;
    margin-bottom: 10px;
  }
  .role-title { font-size: 15px; font-weight: 700; color: var(--text); }
  .company { font-size: 13px; color: var(--accent2); margin-top: 2px; }
  .date {
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    color: var(--text-dim); background: var(--bg2);
    border: 1px solid var(--border); padding: 3px 10px;
    border-radius: 4px; white-space: nowrap; flex-shrink: 0;
  }

  .bullets { margin-top: 10px; padding-left: 16px; }
  .bullets li {
    font-size: 13.5px; color: var(--text-muted);
    margin-bottom: 7px; line-height: 1.65;
  }
  .bullets li::marker { color: var(--accent); }
  .bullets li :global(strong) { color: var(--text); }

  .tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 12px; }
  .tag {
    font-size: 11px; font-weight: 500;
    background: rgba(99,102,241,.1); color: var(--accent3);
    border: 1px solid rgba(99,102,241,.2); padding: 2px 10px; border-radius: 4px;
  }

  @media (max-width: 720px) {
    .header { flex-direction: column; gap: 6px; }
  }
</style>
