    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--bg2); border-top: 1px solid var(--border);
    padding: 32px 0;
  }
  .inner {
    display: flex; align-items: center; justify-content: space-between;
    gap: 16px; flex-wrap: wrap;
  }
  .brand {
    display: flex; align-items: center; gap: 10px;
    font-size: 14px; font-weight: 600; color: var(--text-muted);
  }
  .logo-mark {
    width: 28px; height: 28px; border-radius: 6px;
    background: linear-gradient(135deg, var(--accent), var(--pink));
    display: flex; align-items: center; justify-content: center;
    font-size: 10px; font-weight: 900; color: #fff;
  }
  .copy { font-size: 12px; color: var(--text-dim); }
  .copy a { color: var(--text-muted); }
  .copy a:hover { color: var(--accent3); }
  .social { display: flex; gap: 12px; }
  .social a {
    color: var(--text-dim); transition: color .2s, transform .2s;
    display: flex; align-items: center;
  }
  .social a:hover { color: var(--accent2); transform: translateY(-2px); }
</style>
