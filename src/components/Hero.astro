---
const stats = [
  { num: 9,    suffix: '+', label: 'Years Experience' },
  { num: 5,    suffix: '',  label: 'Companies' },
  { num: 20,   suffix: 'M+', label: 'Daily Events' },
  { num: 40,   suffix: '%', label: 'Latency Reduction' },
];

const roles = ['Staff ML Engineer', 'RAG Architect', 'MLOps Lead', 'LLM Engineer'];
---

<section id="hero">
  <!-- Animated mesh background -->
  <div class="mesh" aria-hidden="true">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    <div class="grid-overlay"></div>
  </div>

  <div class="container">
    <div class="layout">

      <!-- Text -->
      <div class="text">
        <div class="badge reveal">
          <span class="badge-dot"></span>
          Open to new opportunities · Scarborough, Ontario
        </div>

        <h1 class="reveal">
          <span class="name">Sumit Vaise</span>
        </h1>

        <div class="typewriter-wrap reveal">
          <span class="typewriter" id="typewriter"></span>
          <span class="cursor">|</span>
        </div>

        <p class="desc reveal">
          I build AI/ML systems that actually ship — RAG pipelines, production LLM applications,
          and end-to-end MLOps infrastructure that handles millions of events daily across GCP and AWS.
        </p>

        <div class="btns reveal">
          <a href="#projects" class="btn-primary">
            View Projects
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="https://github.com/Sumit1673" target="_blank" rel="noopener" class="btn-ghost">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
            GitHub
          </a>
          <a href="https://linkedin.com/in/sumit-vaise-6644514b" target="_blank" rel="noopener" class="btn-ghost">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.95v5.66H9.36V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.35-1.85 3.58 0 4.24 2.36 4.24 5.43v6.31zM5.34 7.43a2.06 2.06 0 01-2.06-2.06 2.06 2.06 0 012.06-2.06 2.06 2.06 0 012.06 2.06 2.06 2.06 0 01-2.06 2.06zm1.78 13.02H3.56V9h3.56v11.45z"/></svg>
            LinkedIn
          </a>
        </div>

        <!-- Animated stats -->
        <div class="stats reveal">
          {stats.map(s => (
            <div class="stat">
              <span class="stat-num" data-target={s.num} data-suffix={s.suffix}>0</span>
              <span class="stat-label">{s.label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Photo -->
      <div class="photo-col reveal reveal-right">
        <div class="photo-ring">
          <div class="photo-inner">
            <img src="/photo.jpg" alt="Sumit Vaise" />
            <div class="photo-fallback">SV</div>
          </div>
        </div>
        <!-- Floating badges -->
        <div class="float-badge float-1">
          <span>🧠</span> RAG Expert
        </div>
        <div class="float-badge float-2">
          <span>☁️</span> GCP · AWS
        </div>
        <div class="float-badge float-3">
          <span>🚀</span> 9+ Years
        </div>
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-hint" aria-hidden="true">
    <div class="scroll-arrow"></div>
  </div>
</section>

<style>
  section {
    min-height: 100vh;
    display: flex; align-items: center;
    position: relative; overflow: hidden;
    padding: 120px 0 80px;
  }

  /* Mesh background */
  .mesh { position: absolute; inset: 0; pointer-events: none; }
  .orb {
    position: absolute; border-radius: 50%;
    filter: blur(80px); opacity: .55;
  }
  .orb-1 {
    width: 600px; height: 600px; top: -100px; right: -100px;
    background: radial-gradient(circle, rgba(99,102,241,.5) 0%, transparent 70%);
    animation: float 8s ease-in-out infinite;
  }
  .orb-2 {
    width: 400px; height: 400px; bottom: 0; left: -100px;
    background: radial-gradient(circle, rgba(244,114,182,.4) 0%, transparent 70%);
    animation: float 10s ease-in-out infinite reverse;
  }
  .orb-3 {
    width: 300px; height: 300px; top: 40%; left: 40%;
    background: radial-gradient(circle, rgba(52,211,153,.25) 0%, transparent 70%);
    animation: float 12s ease-in-out infinite 2s;
  }
  .grid-overlay {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(99,102,241,.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(99,102,241,.04) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 0%, transparent 100%);
  }

  /* Layout */
  .layout {
    display: grid; grid-template-columns: 1fr auto;
    gap: 64px; align-items: center; position: relative; z-index: 1; width: 100%;
  }

  /* Badge */
  .badge {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 12px; font-weight: 500; color: var(--green);
    background: rgba(52,211,153,.08); border: 1px solid rgba(52,211,153,.2);
    padding: 6px 16px; border-radius: 99px; margin-bottom: 20px;
    backdrop-filter: blur(8px);
  }
  .badge-dot {
    width: 7px; height: 7px; background: var(--green);
    border-radius: 50%; animation: pulse 2s ease-in-out infinite;
  }

  /* Name */
  h1 { margin-bottom: 12px; }
  .name {
    font-size: clamp(40px, 5.5vw, 64px);
    font-weight: 900; letter-spacing: -2.5px;
    line-height: 1.02;
    background: linear-gradient(135deg, #fff 0%, var(--accent3) 60%, var(--pink) 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }

  /* Typewriter */
  .typewriter-wrap {
    font-size: clamp(16px, 2.5vw, 22px);
    font-weight: 600; color: var(--accent2);
    margin-bottom: 20px; min-height: 32px;
    display: flex; align-items: center; gap: 2px;
  }
  .cursor {
    color: var(--accent); font-weight: 400;
    animation: blink 1s step-end infinite;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

  /* Description */
  .desc {
    font-size: 16px; color: var(--text-muted);
    max-width: 520px; line-height: 1.8; margin-bottom: 36px;
  }

  /* Buttons */
  .btns { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 52px; }
  .btn-primary {
    display: inline-flex; align-items: center; gap: 8px;
    background: linear-gradient(135deg, var(--accent) 0%, #7c3aed 100%);
    color: #fff; font-size: 14px; font-weight: 700;
    padding: 13px 28px; border-radius: 10px;
    box-shadow: 0 0 0 1px rgba(99,102,241,.3), 0 8px 32px rgba(99,102,241,.35);
    transition: transform .2s, box-shadow .2s, opacity .2s;
  }
  .btn-primary:hover {
    transform: translateY(-2px); color: #fff;
    box-shadow: 0 0 0 1px rgba(99,102,241,.5), 0 12px 40px rgba(99,102,241,.5);
  }
  .btn-ghost {
    display: inline-flex; align-items: center; gap: 8px;
    border: 1px solid var(--border2); color: var(--text-muted);
    font-size: 14px; font-weight: 500;
    padding: 12px 22px; border-radius: 10px;
    background: rgba(255,255,255,.03);
    transition: border-color .2s, color .2s, transform .2s, background .2s;
  }
  .btn-ghost:hover {
    border-color: var(--accent2); color: var(--text);
    transform: translateY(-2px); background: rgba(99,102,241,.06);
  }

  /* Stats */
  .stats {
    display: flex; gap: 36px; flex-wrap: wrap;
    border-top: 1px solid var(--border); padding-top: 36px;
  }
  .stat { display: flex; flex-direction: column; }
  .stat-num {
    font-size: 28px; font-weight: 800; letter-spacing: -1px;
    background: linear-gradient(135deg, var(--accent3), var(--accent2));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .stat-label { font-size: 12px; color: var(--text-muted); margin-top: 2px; }

  /* Photo */
  .photo-col {
    position: relative; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
  }
  .photo-ring {
    width: 240px; height: 240px; border-radius: 50%;
    padding: 3px;
    background: linear-gradient(135deg, var(--accent) 0%, var(--pink) 50%, var(--accent2) 100%);
    box-shadow: 0 0 60px rgba(99,102,241,.3), 0 0 120px rgba(244,114,182,.15);
    animation: spin 8s linear infinite;
  }
  .photo-inner {
    width: 100%; height: 100%; border-radius: 50%;
    overflow: hidden; background: var(--bg3);
    position: relative; animation: spin 8s linear infinite reverse;
  }
  .photo-inner img {
    position: absolute; inset: 0;
    width: 100%; height: 100%; object-fit: cover; z-index: 2;
  }
  .photo-fallback {
    position: absolute; inset: 0; z-index: 1;
    display: flex; align-items: center; justify-content: center;
    font-size: 64px; font-weight: 900; color: var(--accent2); letter-spacing: -3px;
  }

  /* Floating badges */
  .float-badge {
    position: absolute;
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 12px; font-weight: 600; color: var(--text);
    background: rgba(13,15,24,.85); border: 1px solid var(--border2);
    padding: 7px 14px; border-radius: 99px;
    backdrop-filter: blur(12px);
    white-space: nowrap;
    box-shadow: 0 8px 24px rgba(0,0,0,.4);
  }
  .float-1 { top: 10px; right: -20px; animation: float 5s ease-in-out infinite; }
  .float-2 { bottom: 20px; right: -30px; animation: float 6s ease-in-out infinite 1s; }
  .float-3 { bottom: 60px; left: -30px; animation: float 7s ease-in-out infinite .5s; }

  /* Scroll hint */
  .scroll-hint {
    position: absolute; bottom: 32px; left: 50%;
    transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    opacity: .4; animation: float 2s ease-in-out infinite;
  }
  .scroll-arrow {
    width: 20px; height: 20px; border-right: 2px solid var(--text-muted);
    border-bottom: 2px solid var(--text-muted);
    transform: rotate(45deg);
  }

  @media (max-width: 800px) {
    .layout { grid-template-columns: 1fr; text-align: center; gap: 48px; }
    .photo-col { order: -1; }
    .photo-ring { width: 160px; height: 160px; }
    .photo-fallback { font-size: 44px; }
    .badge, .btns, .stats { justify-content: center; }
    .desc { margin: 0 auto 32px; }
    .float-1 { right: -10px; top: 0; }
    .float-2 { right: -20px; bottom: 0; }
    .float-3 { left: -10px; bottom: 40px; }
    .stats { gap: 20px; justify-content: center; }
    .scroll-hint { display: none; }
  }
</style>

<script>
  // Typewriter effect
  const roles = ['Staff ML Engineer', 'RAG Architect', 'MLOps Lead', 'LLM Engineer'];
  const el = document.getElementById('typewriter')!;
  let ri = 0, ci = 0, deleting = false;

  function type() {
    const word = roles[ri];
    if (!deleting) {
      el.textContent = word.slice(0, ++ci);
      if (ci === word.length) { deleting = true; setTimeout(type, 1800); return; }
    } else {
      el.textContent = word.slice(0, --ci);
      if (ci === 0) { deleting = false; ri = (ri + 1) % roles.length; }
    }
    setTimeout(type, deleting ? 50 : 90);
  }
  setTimeout(type, 800);

  // Stat counter animation
  const statEls = document.querySelectorAll<HTMLElement>('.stat-num');
  const statObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const target = parseInt(el.dataset.target!);
      const suffix = el.dataset.suffix!;
      let start = 0;
      const duration = 1500;
      const step = (timestamp: number) => {
        if (!start) start = timestamp;
        const progress = Math.min((timestamp - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.floor(eased * target) + suffix;
        if (progress < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
      statObserver.unobserve(el);
    });
  }, { threshold: 0.5 });
  statEls.forEach(el => statObserver.observe(el));
</script>
