---
import { posts } from '../data/blog';
---

<section id="blog">
  <div class="container">
    <div class="fade-up">
      <p class="section-tag">Blog</p>
      <h2 class="section-title">Writing about ML</h2>
      <p class="section-lead">
        Thoughts on RAG systems, production ML, and the messy reality of getting models to actually work.
        Published on <a href="https://medium.com/@sumitvaish" target="_blank" rel="noopener">Medium</a>.
      </p>
    </div>

    <div class="grid fade-up">
      {posts.map(p => (
        <a class="card" href={p.href} target="_blank" rel="noopener">
          <div class="thumb">{p.icon}</div>
          <div class="body">
            <div class="meta">
              <span class="date">{p.date}</span>
              <span class="tag">{p.tag}</span>
            </div>
            <div class="title">{p.title}</div>
            <p class="excerpt">{p.excerpt}</p>
            <span class="cta">
              Read on Medium
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>

    <div class="subscribe fade-up">
      <div class="sub-left">
        <h3>Get notified when I publish</h3>
        <p>I write about RAG pipelines, LLMs, MLOps, and lessons from shipping ML to production. No spam — just signal.</p>
        <div class="tiers">
          <span class="tier tier-free">✓ Free tier — all ML articles</span>
          <span class="tier tier-paid">★ Paid tier — coming soon</span>
        </div>
      </div>
      <div>
        <form class="sub-form" id="subForm">
          <input id="subEmail" class="sub-input" type="email" placeholder="your@email.com" required />
          <button class="sub-btn" type="submit">Subscribe →</button>
        </form>
        <p class="sub-note">
          Or follow directly on <a href="https://medium.com/@sumitvaish" target="_blank" rel="noopener">Medium</a>
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 20px; margin-top: 16px;
  }
  .card {
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: var(--radius-lg); overflow: hidden;
    display: flex; flex-direction: column;
    transition: border-color .2s, transform .2s, box-shadow .2s;
    text-decoration: none; color: var(--text);
  }
  .card:hover {
    border-color: var(--accent); color: var(--text);
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(99,102,241,.12);
  }
  .thumb {
    width: 100%; height: 140px;
    background: linear-gradient(135deg, #1a1e2a 0%, #252a38 100%);
    display: flex; align-items: center; justify-content: center;
    font-size: 36px; flex-shrink: 0;
  }
  .body { padding: 20px; flex: 1; display: flex; flex-direction: column; }
  .meta { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
  .date { font-size: 11px; color: var(--text-dim); font-family: 'JetBrains Mono', monospace; }
  .tag {
    font-size: 10px; font-weight: 600; letter-spacing: .5px;
    background: rgba(99,102,241,.1); color: var(--accent3);
    border: 1px solid rgba(99,102,241,.2);
    padding: 2px 8px; border-radius: 4px; text-transform: uppercase;
  }
  .title { font-size: 14px; font-weight: 700; line-height: 1.45; margin-bottom: 8px; }
  .excerpt { font-size: 12.5px; color: var(--text-muted); line-height: 1.6; flex: 1; }
  .cta {
    display: inline-flex; align-items: center; gap: 5px; margin-top: 14px;
    font-size: 12px; font-weight: 600; color: var(--accent2);
  }

  /* Subscribe strip */
  .subscribe {
    margin-top: 56px;
    background: linear-gradient(135deg, rgba(99,102,241,.12) 0%, rgba(99,102,241,.04) 100%);
    border: 1px solid rgba(99,102,241,.25);
    border-radius: var(--radius-lg); padding: 36px 40px;
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 32px; flex-wrap: wrap;
  }
  .sub-left h3 { font-size: 17px; font-weight: 700; margin-bottom: 6px; }
  .sub-left p { font-size: 13.5px; color: var(--text-muted); max-width: 380px; }
  .tiers { display: flex; gap: 10px; margin-top: 12px; flex-wrap: wrap; }
  .tier {
    font-size: 11px; font-weight: 500;
    padding: 3px 12px; border-radius: 100px;
  }
  .tier-free { background: rgba(52,211,153,.1); color: var(--green); border: 1px solid rgba(52,211,153,.2); }
  .tier-paid { background: rgba(251,191,36,.1); color: var(--amber); border: 1px solid rgba(251,191,36,.2); }

  .sub-form { display: flex; gap: 10px; flex-wrap: wrap; }
  .sub-input {
    background: var(--bg3); border: 1px solid var(--border);
    color: var(--text); font-size: 14px; font-family: 'Inter', sans-serif;
    padding: 11px 18px; border-radius: 8px; outline: none; min-width: 210px;
    transition: border-color .2s;
  }
  .sub-input::placeholder { color: var(--text-dim); }
  .sub-input:focus { border-color: var(--accent2); }
  .sub-btn {
    background: var(--accent); color: #fff; font-size: 14px;
    font-weight: 600; font-family: 'Inter', sans-serif;
    padding: 11px 22px; border-radius: 8px; border: none; cursor: pointer;
    transition: background .2s, transform .15s; white-space: nowrap;
  }
  .sub-btn:hover { background: var(--accent2); transform: translateY(-1px); }
  .sub-note { font-size: 12px; color: var(--text-dim); margin-top: 10px; }

  @media (max-width: 720px) {
    .grid { grid-template-columns: 1fr; }
    .subscribe { padding: 28px 24px; }
  }
</style>

<script>
  const form = document.getElementById('subForm') as HTMLFormElement;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = form.querySelector('.sub-btn') as HTMLButtonElement;
    btn.textContent = '✓ Subscribed!';
    btn.style.background = 'var(--green)';
    btn.style.color = '#0d0f14';
    setTimeout(() => {
      btn.textContent = 'Subscribe →';
      btn.style.background = '';
      btn.style.color = '';
      (document.getElementById('subEmail') as HTMLInputElement).value = '';
    }, 3000);
  });
</script>
