---
import { posts } from '../data/blog';
---

<section id="blog">
  <div class="container">
    <div class="reveal">
      <p class="section-eyebrow">Blog</p>
      <h2 class="section-title">Writing about ML</h2>
      <p class="section-lead">
        Thoughts on RAG systems, production ML, and the messy reality of getting models to actually work.
        Published on <a href="https://medium.com/@sumitvaish" target="_blank" rel="noopener">Medium</a>.
      </p>
    </div>

    <div class="grid">
      {posts.map((p, i) => (
        <a class="card reveal reveal-scale" href={p.href} target="_blank" rel="noopener" style={`--i:${i}`}>
          <div class="thumb">
            <div class="thumb-icon">{p.icon}</div>
            <div class="thumb-glow"></div>
          </div>
          <div class="body">
            <div class="meta">
              <span class="date">{p.date}</span>
              <span class="tag">{p.tag}</span>
            </div>
            <h3 class="title">{p.title}</h3>
            <p class="excerpt">{p.excerpt}</p>
            <span class="cta">
              Read on Medium
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>

    <!-- Subscribe -->
    <div class="subscribe reveal">
      <div class="sub-bg"></div>
      <div class="sub-content">
        <div class="sub-left">
          <h3>Get notified when I publish</h3>
          <p>I write about RAG pipelines, LLMs, MLOps, and lessons from shipping ML to production. No spam — just signal.</p>
          <div class="tiers">
            <span class="tier tier-free">✓ Free — all ML articles</span>
            <span class="tier tier-paid">★ Paid tier — coming soon</span>
          </div>
        </div>
        <form class="sub-form" id="subForm">
          <div class="sub-input-row">
            <input id="subEmail" class="sub-input" type="email" placeholder="your@email.com" required />
            <button class="sub-btn" type="submit">Subscribe →</button>
          </div>
          <p class="sub-note">
            Or follow on <a href="https://medium.com/@sumitvaish" target="_blank" rel="noopener">Medium</a>
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  section { background: var(--bg2); }

  .grid {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: 18px;
  }

  .card {
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: var(--radius-lg); overflow: hidden;
    display: flex; flex-direction: column;
    transition: border-color .25s, transform .25s, box-shadow .25s;
    text-decoration: none; color: var(--text);
    transition-delay: calc(var(--i) * 80ms);
  }
  .card:hover {
    border-color: var(--accent); color: var(--text);
    transform: translateY(-6px);
    box-shadow: 0 20px 48px rgba(99,102,241,.15);
  }

  .thumb {
    width: 100%; height: 150px; position: relative;
    background: linear-gradient(135deg, var(--bg4) 0%, var(--bg3) 100%);
    overflow: hidden; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
  }
  .thumb-icon { font-size: 44px; position: relative; z-index: 1; }
  .thumb-glow {
    position: absolute; width: 100px; height: 100px; border-radius: 50%;
    background: radial-gradient(circle, rgba(99,102,241,.3) 0%, transparent 70%);
    transition: transform .4s;
  }
  .card:hover .thumb-glow { transform: scale(2); }

  .body { padding: 20px; flex: 1; display: flex; flex-direction: column; }
  .meta { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
  .date { font-size: 11px; color: var(--text-dim); font-family: 'JetBrains Mono', monospace; }
  .tag {
    font-size: 10px; font-weight: 700; letter-spacing: .8px;
    background: rgba(99,102,241,.1); color: var(--accent3);
    border: 1px solid rgba(99,102,241,.2);
    padding: 2px 8px; border-radius: 4px; text-transform: uppercase;
  }
  .title { font-size: 14px; font-weight: 700; line-height: 1.45; margin-bottom: 10px; }
  .excerpt { font-size: 12.5px; color: var(--text-muted); line-height: 1.65; flex: 1; }
  .cta {
    display: inline-flex; align-items: center; gap: 5px; margin-top: 14px;
    font-size: 12px; font-weight: 700; color: var(--accent2);
    transition: gap .2s;
  }
  .card:hover .cta { gap: 8px; }

  /* Subscribe */
  .subscribe {
    margin-top: 52px; border-radius: var(--radius-xl);
    overflow: hidden; position: relative;
  }
  .sub-bg {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(99,102,241,.14) 0%, rgba(124,58,237,.08) 50%, rgba(244,114,182,.1) 100%);
    border: 1px solid rgba(99,102,241,.25);
    border-radius: var(--radius-xl);
  }
  .sub-content {
    position: relative; z-index: 1;
    display: flex; align-items: center; justify-content: space-between;
    gap: 32px; flex-wrap: wrap; padding: 36px 40px;
  }
  .sub-left h3 { font-size: 18px; font-weight: 700; margin-bottom: 8px; }
  .sub-left p { font-size: 13.5px; color: var(--text-muted); max-width: 380px; }
  .tiers { display: flex; gap: 10px; margin-top: 14px; flex-wrap: wrap; }
  .tier { font-size: 11px; font-weight: 600; padding: 4px 13px; border-radius: 99px; }
  .tier-free { background: rgba(52,211,153,.1); color: var(--green); border: 1px solid rgba(52,211,153,.25); }
  .tier-paid { background: rgba(251,191,36,.1); color: var(--amber); border: 1px solid rgba(251,191,36,.25); }

  .sub-form { flex-shrink: 0; }
  .sub-input-row { display: flex; gap: 8px; flex-wrap: wrap; }
  .sub-input {
    background: rgba(255,255,255,.05); border: 1px solid var(--border2);
    color: var(--text); font-size: 14px; font-family: 'Inter', sans-serif;
    padding: 12px 18px; border-radius: 10px; outline: none; min-width: 210px;
    transition: border-color .2s, background .2s;
    backdrop-filter: blur(8px);
  }
  .sub-input::placeholder { color: var(--text-dim); }
  .sub-input:focus { border-color: var(--accent2); background: rgba(99,102,241,.05); }
  .sub-btn {
    background: linear-gradient(135deg, var(--accent), #7c3aed);
    color: #fff; font-size: 14px; font-weight: 700;
    font-family: 'Inter', sans-serif;
    padding: 12px 22px; border-radius: 10px; border: none; cursor: pointer;
    transition: opacity .2s, transform .15s;
    box-shadow: 0 4px 16px rgba(99,102,241,.35);
    white-space: nowrap;
  }
  .sub-btn:hover { opacity: .9; transform: translateY(-1px); }
  .sub-note { font-size: 12px; color: var(--text-dim); margin-top: 10px; }

  @media (max-width: 720px) {
    .grid { grid-template-columns: 1fr; }
    .sub-content { padding: 28px 24px; }
    .sub-input { min-width: 160px; }
  }
</style>

<script>
  const form = document.getElementById('subForm') as HTMLFormElement;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = form.querySelector('.sub-btn') as HTMLButtonElement;
    btn.textContent = '✓ You\'re in!';
    btn.style.background = 'var(--green)';
    setTimeout(() => {
      btn.textContent = 'Subscribe →';
      btn.style.background = '';
      (document.getElementById('subEmail') as HTMLInputElement).value = '';
    }, 3000);
  });
</script>
