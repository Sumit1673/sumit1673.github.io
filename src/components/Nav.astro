---
const links = [
  { label: 'About',      href: '#about' },
  { label: 'Experience', href: '#experience' },
  { label: 'Projects',   href: '#projects' },
  { label: 'Skills',     href: '#skills' },
  { label: 'Blog',       href: '#blog' },
];
---

<nav>
  <div class="container">
    <a href="/" class="logo">Sumit <span>Vaise</span></a>

    <div class="nav-menu" id="navMenu">
      <ul class="nav-links">
        {links.map(l => <li><a href={l.href}>{l.label}</a></li>)}
        <li><a href="#contact" class="cta">Contact</a></li>
      </ul>
    </div>

    <button class="hamburger" id="hamburger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<style>
  nav {
    position: sticky; top: 0; z-index: 100;
    background: rgba(13,15,20,0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  nav .container {
    display: flex; align-items: center; justify-content: space-between;
    height: 60px;
  }
  .logo {
    font-weight: 700; font-size: 15px; color: var(--text);
    letter-spacing: -.3px;
  }
  .logo span { color: var(--accent2); }
  .logo:hover { color: var(--text); }

  .nav-links {
    display: flex; gap: 28px; list-style: none; align-items: center;
  }
  .nav-links a {
    font-size: 13px; font-weight: 500; color: var(--text-muted);
    transition: color .2s;
  }
  .nav-links a:hover { color: var(--text); }
  .nav-links a.active { color: var(--accent3); }

  .cta {
    font-size: 13px !important; font-weight: 600 !important;
    background: var(--accent); color: #fff !important;
    padding: 7px 18px; border-radius: 6px;
    transition: background .2s, transform .15s !important;
  }
  .cta:hover { background: var(--accent2); transform: translateY(-1px); color: #fff !important; }

  .hamburger {
    display: none; flex-direction: column; gap: 5px;
    background: none; border: none; cursor: pointer; padding: 4px;
  }
  .hamburger span {
    width: 22px; height: 2px; background: var(--text);
    border-radius: 2px; transition: .3s; display: block;
  }

  @media (max-width: 720px) {
    .hamburger { display: flex; }
    .nav-menu {
      display: none; position: absolute; top: 60px; left: 0; right: 0;
      background: var(--bg2); border-bottom: 1px solid var(--border);
      padding: 20px 24px;
    }
    .nav-menu.open { display: block; }
    .nav-links { flex-direction: column; gap: 16px; }
  }
</style>

<script>
  const btn = document.getElementById('hamburger')!;
  const menu = document.getElementById('navMenu')!;

  btn.addEventListener('click', () => menu.classList.toggle('open'));
  document.querySelectorAll('.nav-links a').forEach(a => {
    a.addEventListener('click', () => menu.classList.remove('open'));
  });

  // Active link highlight on scroll
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('.nav-links a[href^="#"]');

  window.addEventListener('scroll', () => {
    let current = '';
    sections.forEach(s => {
      if (window.scrollY >= (s as HTMLElement).offsetTop - 100) current = s.id;
    });
    navLinks.forEach(a => {
      a.classList.toggle('active', a.getAttribute('href') === '#' + current);
    });
  }, { passive: true });
</script>
