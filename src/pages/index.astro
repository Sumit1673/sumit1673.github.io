---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects';
import { posts } from '../data/blog';

const writingPosts = posts.filter(p => p.tag !== 'Productivity').slice(0, 3);
---

<Layout title="Sumit Vaise — Sr ML Engineer" page="home">
<div class="page-sm">

  <!-- ─── Hero ─────────────────────────────────────────────────────────── -->
  <section class="hero rv">
    <div class="hero-top">
      <div class="avatar">
        <img src="/photo.jpg" alt="Sumit Vaise" />
        <div class="avatar-fallback">SV</div>
      </div>
      <div>
        <h1 class="hero-name">Sumit Vaise</h1>
        <p class="hero-role">Sr ML Engineer · Scarborough, ON</p>
      </div>
    </div>

    <p class="hero-bio">
      9 years building end-to-end ML systems — from CNNs and medical imaging to production
      RAG pipelines and LLMOps on GCP and AWS. Led teams of up to 12, shipped 6 production
      systems across fintech, healthcare, and insurance. Open to Staff ML / AI Lead roles
      across Canada and the US.
    </p>

    <div class="social-row">
      <a href="https://github.com/Sumit1673" target="_blank" rel="noopener" class="social-link">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
        GitHub
      </a>
      <span class="sep">·</span>
      <a href="https://linkedin.com/in/sumit-vaise-6644514b" target="_blank" rel="noopener" class="social-link">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        LinkedIn
      </a>
      <span class="sep">·</span>
      <a href="https://medium.com/@sumitvaish" target="_blank" rel="noopener" class="social-link">Medium</a>
      <span class="sep">·</span>
      <a href="mailto:sumitvaise29@gmail.com" class="social-link">Email</a>
      <span class="sep">·</span>
      <a href="https://cal.com/sumit-vaise" target="_blank" rel="noopener" class="social-link">Book a call</a>
      <span class="avail">
        <span class="avail-dot"></span>
        Open to work
      </span>
    </div>
  </section>

  <hr class="divider" />

  <!-- ─── Projects ─────────────────────────────────────────────────────── -->
  <section class="section">
    <h2 class="section-heading rv">Selected work</h2>
    <ul class="item-list" role="list">
      {projects.map((p, i) => (
        <li class="project-row rv" data-d={i * 60}>
          <div class="pr-left">
            <span class="pr-icon" aria-hidden="true">{p.icon}</span>
            <div class="pr-info">
              <span class="pr-title">{p.title}</span>
              <div class="pr-tags">
                {p.tags.slice(0, 3).map(t => <span class="chip">{t}</span>)}
                {p.corporate && <span class="corp-chip">corporate</span>}
              </div>
            </div>
          </div>
          <div class="pr-right">
            {!p.corporate && p.links[0] && (
              <a href={p.links[0].href} target="_blank" rel="noopener" class="row-link">
                Code →
              </a>
            )}
          </div>
        </li>
      ))}
    </ul>
    <a href="/projects" class="see-all rv">View all projects →</a>
  </section>

  <hr class="divider" />

  <!-- ─── Writing ──────────────────────────────────────────────────────── -->
  <section class="section">
    <h2 class="section-heading rv">Writing</h2>
    <ul class="item-list" role="list">
      {writingPosts.map((p, i) => (
        <li class="rv" data-d={i * 60}>
          <a href={p.href} target="_blank" rel="noopener" class="post-row">
            <span class="post-date">{p.date}</span>
            <span class="post-title">{p.title}</span>
            <span class="post-arrow">→</span>
          </a>
        </li>
      ))}
    </ul>
    <a href="https://medium.com/@sumitvaish" target="_blank" rel="noopener" class="see-all rv">
      All posts on Medium →
    </a>
  </section>

</div>
</Layout>

<style>
  /* ─── Hero ──────────────────────────────────────────────────────── */
  .hero { padding: 56px 0 48px; }

  .hero-top {
    display: flex; align-items: center; gap: 16px; margin-bottom: 24px;
  }

  .avatar {
    width: 72px; height: 72px; border-radius: 50%; flex-shrink: 0;
    overflow: hidden; position: relative;
    border: 2px solid var(--border2); background: var(--bg3);
  }
  .avatar img {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; z-index: 2;
  }
  .avatar-fallback {
    position: absolute; inset: 0; z-index: 1;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px; font-weight: 900; color: var(--accent2);
  }

  .hero-name {
    font-size: 22px; font-weight: 800; letter-spacing: -.5px;
    color: var(--text); margin-bottom: 3px;
  }
  .hero-role { font-size: 14px; color: var(--text-3); }

  .hero-bio {
    font-size: 15px; color: var(--text-2); line-height: 1.8;
    max-width: 620px; margin-bottom: 24px;
  }

  /* ─── Social row ─────────────────────────────────────────────── */
  .social-row {
    display: flex; align-items: center; flex-wrap: wrap; gap: 6px;
  }
  .social-link {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 13px; font-weight: 500; color: var(--text-2);
    transition: color .15s;
  }
  .social-link:hover { color: var(--text); }
  .sep { color: var(--text-3); font-size: 13px; }

  .avail {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 13px; color: var(--green); margin-left: 4px;
  }
  .avail-dot {
    width: 6px; height: 6px; border-radius: 50%; background: var(--green);
    flex-shrink: 0; animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot { 0%,100%{opacity:1} 50%{opacity:.35} }

  /* ─── Shared section ─────────────────────────────────────────── */
  .divider {
    border: none; border-top: 1px solid var(--border); margin: 0;
  }
  .section { padding: 40px 0; }
  .section-heading {
    font-size: 12px; font-weight: 600; letter-spacing: 1px;
    text-transform: uppercase; font-family: var(--mono);
    color: var(--text-3); margin-bottom: 20px;
  }

  .item-list { list-style: none; display: flex; flex-direction: column; }

  /* ─── Project rows ───────────────────────────────────────────── */
  .project-row {
    display: flex; align-items: center; justify-content: space-between;
    gap: 16px; padding: 14px 0;
    border-bottom: 1px solid var(--border);
  }
  .project-row:last-child { border-bottom: none; }

  .pr-left { display: flex; align-items: center; gap: 12px; min-width: 0; }
  .pr-icon { font-size: 18px; flex-shrink: 0; }
  .pr-info { display: flex; flex-direction: column; gap: 6px; min-width: 0; }
  .pr-title { font-size: 14px; font-weight: 600; color: var(--text); }
  .pr-tags { display: flex; flex-wrap: wrap; gap: 5px; }

  .corp-chip {
    font-family: var(--mono); font-size: 10px; font-weight: 600;
    color: var(--amber); background: rgba(251,191,36,.08);
    border: 1px solid rgba(251,191,36,.2); padding: 2px 8px; border-radius: 4px;
    letter-spacing: .5px;
  }

  .pr-right { flex-shrink: 0; }
  .row-link {
    font-size: 12px; font-weight: 600; color: var(--text-3);
    transition: color .15s; white-space: nowrap;
  }
  .row-link:hover { color: var(--accent3); }

  /* ─── Post rows ──────────────────────────────────────────────── */
  .post-row {
    display: flex; align-items: baseline; gap: 14px;
    padding: 13px 0; border-bottom: 1px solid var(--border);
    color: var(--text-2); transition: color .15s;
  }
  li:last-child .post-row { border-bottom: none; }
  .post-row:hover { color: var(--text); }

  .post-date {
    font-family: var(--mono); font-size: 11px; color: var(--text-3);
    white-space: nowrap; flex-shrink: 0; min-width: 70px;
  }
  .post-title { font-size: 14px; font-weight: 500; flex: 1; line-height: 1.4; }
  .post-arrow { font-size: 13px; color: var(--text-3); flex-shrink: 0; transition: color .15s; }
  .post-row:hover .post-arrow { color: var(--accent3); }

  /* ─── See all link ───────────────────────────────────────────── */
  .see-all {
    display: inline-block; margin-top: 20px;
    font-size: 13px; font-weight: 600; color: var(--accent3);
    border-bottom: 1px solid rgba(165,180,252,.3); padding-bottom: 1px;
    transition: border-color .15s, color .15s;
  }
  .see-all:hover { color: var(--accent); border-color: var(--accent); }

  @media (max-width: 560px) {
    .hero { padding: 40px 0 36px; }
    .social-row { gap: 5px; }
    .pr-tags { display: none; }
    .post-date { min-width: 60px; }
  }
</style>
