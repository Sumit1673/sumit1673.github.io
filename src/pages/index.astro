---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects';
import { posts } from '../data/blog';

const featured = projects[0];
const recent = posts.slice(0, 2);
---

<Layout page="home">
<div class="page">

  <!-- ─── Hero ──────────────────────────────────────────────────────── -->
  <section class="hero rv">
    <div class="hero-text">
      <span class="eyebrow">Staff ML Engineer · Scarborough, ON</span>
      <h1 class="display">
        Building ML systems<br/>
        <span>that ship.</span>
      </h1>
      <p class="hero-sub">
        I specialise in RAG pipelines, production LLM applications, and end-to-end
        MLOps infrastructure that handles millions of events daily on GCP and AWS.
        9 years turning notebooks into production systems.
      </p>
      <div class="hero-actions">
        <a href="/work" class="btn-primary">View my work →</a>
        <a href="/about" class="btn-ghost">About me</a>
      </div>
    </div>
    <div class="hero-card rv" data-d="150">
      <div class="hero-card-header">
        <span class="mono-label">// current_status.py</span>
        <span class="status-dot"></span>
      </div>
      <pre class="code-block"><code><span class="c">name</span>    <span class="eq">=</span> <span class="s">"Sumit Vaise"</span>
<span class="c">role</span>    <span class="eq">=</span> <span class="s">"Staff ML Engineer"</span>
<span class="c">stack</span>   <span class="eq">=</span> [<span class="s">"RAG"</span>, <span class="s">"LangChain"</span>, <span class="s">"GCP"</span>, <span class="s">"AWS"</span>]
<span class="c">open_to</span> <span class="eq">=</span> <span class="kw">True</span>  <span class="cm"># new opportunities</span></code></pre>
      <div class="hero-metrics">
        <div class="hm-item">
          <span class="hm-val">9+</span>
          <span class="hm-label">Years</span>
        </div>
        <div class="hm-item">
          <span class="hm-val">20M+</span>
          <span class="hm-label">Daily events</span>
        </div>
        <div class="hm-item">
          <span class="hm-val">40%</span>
          <span class="hm-label">Latency cut</span>
        </div>
        <div class="hm-item">
          <span class="hm-val">0.92</span>
          <span class="hm-label">RAG faithfulness</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Tech bar ──────────────────────────────────────────────────── -->
  <section class="tech-bar rv" data-d="200">
    <span class="tb-label">Core stack</span>
    <div class="tb-chips">
      {['Python', 'LangChain', 'PyTorch', 'Vertex AI', 'SageMaker', 'Kubernetes', 'MLflow', 'FastAPI', 'ChromaDB', 'RAGAS'].map(t => (
        <span class="tb-chip">{t}</span>
      ))}
    </div>
  </section>

  <!-- ─── Featured project ──────────────────────────────────────────── -->
  <section class="featured-section">
    <div class="rv">
      <span class="eyebrow">Featured work</span>
      <h2 class="heading">Latest build</h2>
    </div>
    <div class="featured-card rv" data-d="100">
      <div class="fc-left">
        <div class="fc-icon">{featured.icon}</div>
        <div class="fc-badge">Featured</div>
        <h3 class="fc-title">{featured.title}</h3>
        <p class="fc-desc">{featured.description}</p>
        {featured.metrics && (
          <div class="fc-metrics">
            {featured.metrics.map(m => (
              <div class="fc-metric">
                <span class="fc-val">{m.value}</span>
                <span class="fc-lbl">{m.label}</span>
              </div>
            ))}
          </div>
        )}
        <div class="fc-tags">
          {featured.tags.map(t => <span class="chip">{t}</span>)}
        </div>
        <div class="fc-links">
          {featured.links.map(l => (
            <a href={l.href} target="_blank" rel="noopener" class:list={['fc-link', { primary: l.featured }]}>
              {l.label} →
            </a>
          ))}
        </div>
      </div>
      <div class="fc-right">
        <div class="fc-diagram">
          <div class="diagram-node top">Documents</div>
          <div class="diagram-arrow">↓</div>
          <div class="diagram-row">
            <div class="diagram-node small">BM25</div>
            <span class="diagram-plus">+</span>
            <div class="diagram-node small accent">Dense</div>
          </div>
          <div class="diagram-arrow">↓ RRF</div>
          <div class="diagram-node">Reranker</div>
          <div class="diagram-arrow">↓</div>
          <div class="diagram-node accent-fill">LLM Answer</div>
          <div class="diagram-score">
            <span class="chip">Faithfulness 0.92</span>
            <span class="chip">Relevancy 0.88</span>
          </div>
        </div>
      </div>
    </div>
    <a href="/work" class="see-all rv" data-d="150">See all projects →</a>
  </section>

  <!-- ─── Recent posts ──────────────────────────────────────────────── -->
  <section class="posts-section">
    <div class="rv">
      <span class="eyebrow">Writing</span>
      <h2 class="heading">Latest from the blog</h2>
    </div>
    <div class="posts-grid">
      {recent.map((p, i) => (
        <a href={p.href} target="_blank" rel="noopener" class="post-card rv" data-d={i * 80}>
          <div class="post-thumb">{p.icon}</div>
          <div class="post-body">
            <div class="post-meta">
              <span class="post-date">{p.date}</span>
              <span class="post-tag">{p.tag}</span>
            </div>
            <h3 class="post-title">{p.title}</h3>
            <p class="post-exc">{p.excerpt}</p>
            <span class="post-cta">Read →</span>
          </div>
        </a>
      ))}
    </div>
    <a href="/blog" class="see-all rv">See all posts →</a>
  </section>

</div>
</Layout>

<style>
  /* ─── Hero ─────────────────────────────────────────────────── */
  .hero {
    display: grid; grid-template-columns: 1fr 420px;
    gap: 48px; align-items: center; padding: 32px 0 80px;
  }
  .hero-sub {
    font-size: 15px; color: var(--text-2); line-height: 1.8;
    max-width: 500px; margin-bottom: 32px;
  }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }

  .btn-primary {
    display: inline-flex; align-items: center; gap: 6px;
    background: var(--accent2); color: #fff; font-size: 14px; font-weight: 600;
    padding: 10px 22px; border-radius: var(--r); border: 1px solid transparent;
    transition: background .15s, transform .15s;
  }
  .btn-primary:hover { background: var(--accent); transform: translateY(-1px); color: #fff; }
  .btn-ghost {
    display: inline-flex; align-items: center; gap: 6px;
    border: 1px solid var(--border2); color: var(--text-2);
    font-size: 14px; font-weight: 500;
    padding: 10px 22px; border-radius: var(--r);
    transition: border-color .15s, color .15s;
  }
  .btn-ghost:hover { border-color: var(--accent); color: var(--text); }

  /* Code card */
  .hero-card {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: var(--r3); overflow: hidden;
  }
  .hero-card-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 16px; border-bottom: 1px solid var(--border);
    background: var(--bg3);
  }
  .mono-label { font-family: var(--mono); font-size: 11px; color: var(--text-3); }
  .status-dot {
    width: 7px; height: 7px; border-radius: 50%; background: var(--green);
    box-shadow: 0 0 8px rgba(74,222,128,.5);
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot { 0%,100%{opacity:1} 50%{opacity:.4} }

  .code-block {
    padding: 20px 16px; font-family: var(--mono); font-size: 13px;
    line-height: 1.8; border-bottom: 1px solid var(--border);
    overflow-x: auto;
  }
  .code-block .c  { color: var(--accent3); }
  .code-block .eq { color: var(--text-3); }
  .code-block .s  { color: #86efac; }
  .code-block .kw { color: #fda4af; }
  .code-block .cm { color: var(--text-3); }

  .hero-metrics {
    display: grid; grid-template-columns: repeat(4, 1fr);
    padding: 0;
  }
  .hm-item {
    padding: 14px 0; text-align: center;
    border-right: 1px solid var(--border);
  }
  .hm-item:last-child { border-right: none; }
  .hm-val { display: block; font-family: var(--mono); font-size: 16px; font-weight: 700; color: var(--accent3); }
  .hm-label { font-size: 10px; color: var(--text-3); margin-top: 2px; display: block; }

  /* ─── Tech bar ──────────────────────────────────────────────── */
  .tech-bar {
    display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
    padding: 20px 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
    margin-bottom: 80px;
  }
  .tb-label { font-family: var(--mono); font-size: 11px; color: var(--text-3); white-space: nowrap; }
  .tb-chips { display: flex; gap: 6px; flex-wrap: wrap; }
  .tb-chip {
    font-family: var(--mono); font-size: 11px; color: var(--text-2);
    background: var(--bg3); border: 1px solid var(--border);
    padding: 3px 10px; border-radius: 4px;
  }

  /* ─── Featured ──────────────────────────────────────────────── */
  .featured-section { margin-bottom: 80px; }
  .featured-card {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: var(--r3); overflow: hidden; margin: 24px 0 16px;
    display: grid; grid-template-columns: 1fr 360px;
  }
  .fc-left { padding: 32px; display: flex; flex-direction: column; gap: 16px; }
  .fc-icon { font-size: 32px; }
  .fc-badge {
    display: inline-block; font-family: var(--mono); font-size: 10px; font-weight: 600;
    letter-spacing: 1px; text-transform: uppercase;
    background: rgba(99,102,241,.12); color: var(--accent3);
    border: 1px solid rgba(99,102,241,.25); padding: 3px 10px; border-radius: 4px; width: fit-content;
  }
  .fc-title { font-size: 20px; font-weight: 700; letter-spacing: -.5px; }
  .fc-desc { font-size: 13.5px; color: var(--text-2); line-height: 1.75; }
  .fc-metrics { display: flex; gap: 12px; flex-wrap: wrap; }
  .fc-metric {
    background: var(--bg3); border: 1px solid var(--border);
    border-radius: var(--r); padding: 10px 14px; min-width: 80px;
  }
  .fc-val { display: block; font-family: var(--mono); font-size: 18px; font-weight: 700; color: var(--green); }
  .fc-lbl { font-size: 11px; color: var(--text-3); }
  .fc-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .fc-links { display: flex; gap: 10px; }
  .fc-link {
    font-size: 13px; font-weight: 600; color: var(--text-2);
    border: 1px solid var(--border); padding: 8px 16px; border-radius: var(--r);
    transition: border-color .15s, color .15s;
  }
  .fc-link:hover { border-color: var(--accent); color: var(--accent3); }
  .fc-link.primary {
    background: var(--accent2); color: #fff !important; border-color: var(--accent2) !important;
  }
  .fc-link.primary:hover { background: var(--accent); border-color: var(--accent) !important; }

  /* Diagram */
  .fc-right {
    background: var(--bg3); border-left: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    padding: 32px;
  }
  .fc-diagram {
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    font-size: 12px; width: 100%;
  }
  .diagram-node {
    background: var(--bg4); border: 1px solid var(--border);
    border-radius: 6px; padding: 7px 18px;
    font-family: var(--mono); font-size: 11px; color: var(--text-2);
    text-align: center; width: 100%; max-width: 180px;
  }
  .diagram-node.top { background: var(--bg2); }
  .diagram-node.accent { border-color: rgba(99,102,241,.4); color: var(--accent3); }
  .diagram-node.accent-fill { background: rgba(99,102,241,.12); border-color: rgba(99,102,241,.4); color: var(--accent3); }
  .diagram-node.small { max-width: 80px; padding: 6px 10px; }
  .diagram-arrow { font-family: var(--mono); font-size: 11px; color: var(--text-3); }
  .diagram-row { display: flex; align-items: center; gap: 6px; width: 100%; justify-content: center; }
  .diagram-plus { font-size: 14px; color: var(--text-3); }
  .diagram-score { display: flex; flex-wrap: wrap; gap: 4px; justify-content: center; margin-top: 4px; }

  /* ─── Posts ─────────────────────────────────────────────────── */
  .posts-section { margin-bottom: 40px; }
  .posts-grid {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: 16px; margin: 24px 0 16px;
  }
  .post-card {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: var(--r2); overflow: hidden; display: flex;
    transition: border-color .2s, transform .2s; color: var(--text);
  }
  .post-card:hover { border-color: var(--border2); transform: translateY(-2px); color: var(--text); }
  .post-thumb {
    width: 80px; flex-shrink: 0;
    background: var(--bg3); display: flex; align-items: center; justify-content: center;
    font-size: 28px; border-right: 1px solid var(--border);
  }
  .post-body { padding: 16px; display: flex; flex-direction: column; gap: 6px; }
  .post-meta { display: flex; align-items: center; gap: 8px; }
  .post-date { font-family: var(--mono); font-size: 10px; color: var(--text-3); }
  .post-tag {
    font-family: var(--mono); font-size: 10px; font-weight: 600;
    background: rgba(99,102,241,.1); color: var(--accent3);
    border: 1px solid rgba(99,102,241,.2); padding: 1px 7px; border-radius: 3px;
    text-transform: uppercase;
  }
  .post-title { font-size: 13px; font-weight: 700; line-height: 1.4; }
  .post-exc { font-size: 12px; color: var(--text-2); line-height: 1.6; }
  .post-cta { font-size: 12px; font-weight: 600; color: var(--accent); margin-top: auto; }

  .see-all {
    display: inline-block; font-size: 13px; font-weight: 600;
    color: var(--accent3); border-bottom: 1px solid rgba(165,180,252,.3);
    padding-bottom: 1px;
    transition: border-color .15s, color .15s;
  }
  .see-all:hover { color: var(--accent); border-color: var(--accent); }

  @media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; }
    .hero-card { max-width: 480px; }
    .hero-metrics { grid-template-columns: repeat(2, 1fr); }
    .hm-item:nth-child(2) { border-right: none; }
    .featured-card { grid-template-columns: 1fr; }
    .fc-right { border-left: none; border-top: 1px solid var(--border); }
  }
  @media (max-width: 640px) {
    .posts-grid { grid-template-columns: 1fr; }
    .tech-bar { flex-direction: column; align-items: flex-start; }
  }
</style>
