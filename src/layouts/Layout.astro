---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Sumit Vaise — Staff ML Engineer',
  description = 'Staff ML Engineer specialising in RAG pipelines, production LLM applications, and end-to-end MLOps on GCP and AWS.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:        #0d0f14;
    --bg2:       #13161e;
    --bg3:       #1a1e2a;
    --border:    #252a38;
    --accent:    #6366f1;
    --accent2:   #818cf8;
    --accent3:   #a5b4fc;
    --text:      #e2e8f0;
    --text-muted:#8892a4;
    --text-dim:  #4a5568;
    --green:     #34d399;
    --amber:     #fbbf24;
    --radius:    10px;
    --radius-lg: 16px;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
  }

  a { color: var(--accent2); text-decoration: none; transition: color .2s; }
  a:hover { color: var(--accent3); }
  img { display: block; max-width: 100%; }

  .container { max-width: 900px; margin: 0 auto; padding: 0 24px; }

  section { padding: 88px 0; }
  section:nth-child(even) { background: var(--bg2); }

  /* Section headings */
  .section-tag {
    font-size: 11px; font-weight: 600; letter-spacing: 2px;
    text-transform: uppercase; color: var(--accent2); margin-bottom: 8px;
  }
  .section-title {
    font-size: clamp(22px, 3.5vw, 32px); font-weight: 700;
    letter-spacing: -.5px; margin-bottom: 14px;
  }
  .section-lead { font-size: 15px; color: var(--text-muted); max-width: 560px; margin-bottom: 48px; }

  /* Fade-in animations */
  .fade-up { opacity: 0; transform: translateY(20px); transition: opacity .55s ease, transform .55s ease; }
  .fade-up.visible { opacity: 1; transform: translateY(0); }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: .5; transform: scale(1.4); }
  }
  @keyframes spin { to { transform: rotate(360deg); } }
</style>
