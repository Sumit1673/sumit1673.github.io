---
interface Props {
  title?: string;
  description?: string;
  page?: string;
}

const {
  title = 'Sumit Vaise | Senior ML Engineer',
  description = 'Senior ML Engineer specialising in RAG pipelines, production LLM applications, and end-to-end MLOps on GCP and AWS.',
  page = '',
} = Astro.props;

const nav = [
  { label: 'Home',     href: '/' },
  { label: 'Projects', href: '/projects' },
  { label: 'About',    href: '/about' },
  { label: 'Blog',     href: '/blog' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div id="progress"></div>

    <header>
      <div class="hdr-inner">
        <a href="/" class="logo">
          <span class="logo-icon">SV</span>
        </a>

        <nav>
          {nav.map(n => (
            <a href={n.href} class:list={[{ active: page === n.label.toLowerCase() }]}>{n.label}</a>
          ))}
        </nav>

        <div class="hdr-social">
          <a href="https://github.com/Sumit1673" target="_blank" rel="noopener" aria-label="GitHub" class="hdr-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <a href="https://linkedin.com/in/sumit-vaise-6644514b" target="_blank" rel="noopener" aria-label="LinkedIn" class="hdr-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
        <a href="mailto:sumitvaise29@gmail.com" class="hdr-cta">Contact</a>

        <button class="burger" id="burger" aria-label="Menu">
          <span></span><span></span><span></span>
        </button>
      </div>

      <!-- Mobile menu -->
      <div class="mobile-nav" id="mobileNav">
        {nav.map(n => (
          <a href={n.href} class:list={[{ active: page === n.label.toLowerCase() }]}>{n.label}</a>
        ))}
        <a href="mailto:sumitvaise29@gmail.com" class="mobile-cta">Contact</a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="ft-inner">
        <span class="ft-name">Sumit Vaise</span>
        <span class="ft-copy">Senior ML Engineer · © {new Date().getFullYear()}</span>
        <div class="ft-links">
          <a href="https://github.com/Sumit1673" target="_blank" rel="noopener">GitHub</a>
          <a href="https://linkedin.com/in/sumit-vaise-6644514b" target="_blank" rel="noopener">LinkedIn</a>
          <a href="https://medium.com/@sumitvaish" target="_blank" rel="noopener">Medium</a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:       #09090b;
    --bg2:      #111116;
    --bg3:      #18181f;
    --bg4:      #1f1f2a;
    --border:   #27272f;
    --border2:  #38384a;
    --accent:   #818cf8;
    --accent2:  #6366f1;
    --accent3:  #a5b4fc;
    --green:    #4ade80;
    --amber:    #fbbf24;
    --red:      #f87171;
    --text:     #fafafa;
    --text-2:   #a1a1aa;
    --text-3:   #52525b;
    --mono:     'JetBrains Mono', monospace;
    --r:        8px;
    --r2:       12px;
    --r3:       16px;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  a { color: inherit; text-decoration: none; }
  img { display: block; max-width: 100%; }
  strong { font-weight: 600; color: var(--text); }

  /* Progress bar */
  #progress {
    position: fixed; top: 0; left: 0; z-index: 999;
    height: 2px; width: 0;
    background: linear-gradient(90deg, var(--accent2), var(--accent), #c4b5fd);
    pointer-events: none; transition: width .08s linear;
  }

  /* Header */
  header {
    position: sticky; top: 0; z-index: 100;
    border-bottom: 1px solid var(--border);
    background: rgba(9,9,11,.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }
  .hdr-inner {
    max-width: 1100px; margin: 0 auto; padding: 0 32px;
    height: 56px; display: flex; align-items: center; gap: 8px;
  }
  .logo {
    margin-right: auto;
    display: flex; align-items: center;
  }
  .logo-icon {
    width: 30px; height: 30px; border-radius: 7px;
    background: linear-gradient(135deg, var(--accent2), #7c3aed);
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 900; color: #fff; letter-spacing: -.5px;
  }

  header nav { display: flex; gap: 2px; }
  header nav a {
    font-size: 13px; font-weight: 500; color: var(--text-2);
    padding: 5px 12px; border-radius: 6px;
    transition: color .15s, background .15s;
  }
  header nav a:hover { color: var(--text); background: rgba(255,255,255,.05); }
  header nav a.active { color: var(--text); }

  .hdr-social { display: flex; align-items: center; gap: 2px; margin-left: 4px; }
  .hdr-icon {
    display: flex; align-items: center; justify-content: center;
    width: 30px; height: 30px; border-radius: 6px;
    color: var(--text-3); transition: color .15s, background .15s;
  }
  .hdr-icon:hover { color: var(--text-2); background: rgba(255,255,255,.05); }

  .hdr-cta {
    font-size: 13px; font-weight: 600; color: var(--text);
    border: 1px solid var(--border2);
    padding: 5px 16px; border-radius: 6px; margin-left: 8px;
    transition: border-color .15s, background .15s;
  }
  .hdr-cta:hover { border-color: var(--accent); background: rgba(99,102,241,.06); color: var(--text); }

  .burger {
    display: none; flex-direction: column; gap: 4px;
    background: none; border: none; cursor: pointer; padding: 4px; margin-left: 8px;
  }
  .burger span { width: 20px; height: 1.5px; background: var(--text-2); display: block; transition: .25s; border-radius: 2px; }
  .burger.open span:nth-child(1) { transform: translateY(5.5px) rotate(45deg); }
  .burger.open span:nth-child(2) { opacity: 0; }
  .burger.open span:nth-child(3) { transform: translateY(-5.5px) rotate(-45deg); }

  .mobile-nav {
    display: none; flex-direction: column; gap: 2px;
    padding: 12px 24px 16px; border-top: 1px solid var(--border);
    background: var(--bg2);
  }
  .mobile-nav.open { display: flex; }
  .mobile-nav a { font-size: 14px; font-weight: 500; color: var(--text-2); padding: 10px 12px; border-radius: 6px; }
  .mobile-nav a:hover, .mobile-nav a.active { color: var(--text); background: rgba(255,255,255,.04); }
  .mobile-cta { color: var(--accent3) !important; }

  @media (max-width: 640px) {
    .hdr-cta, header nav, .hdr-social { display: none; }
    .burger { display: flex; }
  }

  /* Main */
  main { min-height: calc(100vh - 56px - 60px); }

  /* Shared page container */
  .page { max-width: 1100px; margin: 0 auto; padding: 72px 32px; }
  .page-sm { max-width: 760px; margin: 0 auto; padding: 72px 32px; }

  /* Footer */
  footer { border-top: 1px solid var(--border); background: var(--bg2); }
  .ft-inner {
    max-width: 1100px; margin: 0 auto; padding: 16px 32px;
    display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
  }
  .ft-name { font-size: 13px; font-weight: 600; color: var(--text); }
  .ft-copy { font-size: 12px; color: var(--text-3); margin-right: auto; }
  .ft-links { display: flex; gap: 16px; }
  .ft-links a { font-size: 12px; color: var(--text-3); transition: color .15s; }
  .ft-links a:hover { color: var(--text-2); }

  /* Typography */
  .eyebrow {
    font-family: var(--mono); font-size: 11px; font-weight: 500;
    letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--accent); margin-bottom: 12px; display: block;
  }
  h1.display {
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 900; letter-spacing: -2px; line-height: 1.05;
    color: var(--text); margin-bottom: 20px;
  }
  h1.display span { color: var(--accent3); }
  h2.heading {
    font-size: clamp(22px, 3vw, 30px);
    font-weight: 800; letter-spacing: -1px; margin-bottom: 12px;
  }

  /* Shared card */
  .card {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: var(--r2); padding: 24px;
    transition: border-color .2s;
  }
  .card:hover { border-color: var(--border2); }

  /* Tag chip */
  .chip {
    display: inline-block;
    font-family: var(--mono); font-size: 11px; font-weight: 500;
    background: var(--bg3); border: 1px solid var(--border);
    color: var(--text-2); padding: 3px 9px; border-radius: 4px;
  }

  /* Metric pill */
  .metric-pill {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: var(--mono); font-size: 12px; font-weight: 600;
    background: rgba(74,222,128,.08); color: var(--green);
    border: 1px solid rgba(74,222,128,.2); padding: 4px 12px; border-radius: 99px;
  }
  .metric-pill::before {
    content: '▲'; font-size: 9px;
  }

  /* Reveal */
  .rv {
    opacity: 0; transform: translateY(20px);
    transition: opacity .6s cubic-bezier(.16,1,.3,1), transform .6s cubic-bezier(.16,1,.3,1);
  }
  .rv.in { opacity: 1; transform: none; }

  @media (max-width: 640px) {
    .page, .page-sm { padding: 48px 20px; }
  }
</style>

<script>
  // Progress bar
  const prog = document.getElementById('progress')!;
  window.addEventListener('scroll', () => {
    const pct = window.scrollY / (document.body.scrollHeight - window.innerHeight) * 100;
    prog.style.width = pct + '%';
  }, { passive: true });

  // Mobile menu
  const burger = document.getElementById('burger')!;
  const mobileNav = document.getElementById('mobileNav')!;
  burger.addEventListener('click', () => {
    burger.classList.toggle('open');
    mobileNav.classList.toggle('open');
  });
  mobileNav.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
    burger.classList.remove('open');
    mobileNav.classList.remove('open');
  }));

  // Reveal on scroll
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        const el = e.target as HTMLElement;
        setTimeout(() => el.classList.add('in'), +(el.dataset.d ?? 0));
        io.unobserve(el);
      }
    });
  }, { threshold: 0.08 });
  document.querySelectorAll('.rv').forEach((el, i) => {
    const e = el as HTMLElement;
    if (!e.dataset.d) e.dataset.d = String(Math.min(i % 6 * 80, 320));
    io.observe(e);
  });
</script>
